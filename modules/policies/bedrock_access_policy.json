{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowInvokeOnlyApprovedInferenceProfile",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": [
        "${inference_profile_arn}",
        "arn:aws:bedrock:us-east-1:${account_id}:inference-profile/*.anthropic.claude-sonnet-4-5-20250929-v1:0",
        "arn:aws:bedrock:*::foundation-model/anthropic.claude-sonnet-4-5-20250929-v1:0"
      ]
    }
  ]
}